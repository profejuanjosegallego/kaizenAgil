# Copia este archivo a ".env.local" y rellena los valores reales.
# NUNCA subas .env.local al repositorio (ya esta en .gitignore).

# Cadena de conexion de MongoDB Atlas (o local).
# Ej: mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/revuelta_tablero?retryWrites=true&w=majority
MONGODB_URI=

# Secreto para firmar los JWT. Usa una cadena larga y aleatoria.
# Puedes generar una con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Credenciales del primer usuario docente (se crean al correr "npm run seed").
SEED_ADMIN_NAME=Docente
SEED_ADMIN_EMAIL=docente@revuelta.edu
SEED_ADMIN_PASSWORD=cambiar123

# Correo (opcional). Si lo dejas vacío, se usa una cuenta de prueba Ethereal
# y el enlace para ver el correo aparece en la consola del servidor.
# Para Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_USER=tucorreo@gmail.com,
# SMTP_PASS=<contraseña de aplicación de Google> (no tu contraseña normal).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Kaizen <no-reply@kaizen.local>"
